# ═══════════════════════════════════════════════════════
#  أسد السوق — The Market Lion — Environment Variables
#  Copy this file to .env and fill in your API keys.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Core Security (REQUIRED — do not leave defaults in production) ──────────
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars_replace_now
ENCRYPTION_KEY=                    # Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Database Credentials ───────────────────────────────────────────────────
PG_USER=lion
PG_PASSWORD=                       # Change in production
MONGO_USER=lion
MONGO_PASSWORD=                    # Change in production
REDIS_PASSWORD=                    # Change in production
GRAFANA_PASSWORD=                  # Grafana admin password

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Market Data APIs ───────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=                 # https://alphavantage.co (free: 25 req/day)
TWELVE_DATA_KEY=                   # https://twelvedata.com (optional)
POLYGON_KEY=                       # https://polygon.io (optional)

# ── News & NLP ─────────────────────────────────────────────────────────────
NEWSAPI_KEY=                       # https://newsapi.org (free: 100 req/day)
NEWS_API_KEY=                      # alias for NEWSAPI_KEY
GNEWS_KEY=                         # https://gnews.io (optional)
TWITTER_BEARER=                    # Twitter/X API v2 bearer token

# ── Economic Data ──────────────────────────────────────────────────────────
FRED_API_KEY=                      # https://fred.stlouisfed.org/docs/api/ (free)
GLASSNODE_API_KEY=                 # https://glassnode.com (on-chain data)

# ── Broker APIs (fill only the broker you use) ─────────────────────────────
METAAPI_TOKEN=                     # https://metaapi.cloud (MT4/MT5 via cloud)
CAPITAL_COM_API_KEY=               # Capital.com API key
CAPITAL_COM_PASSWORD=              # Capital.com password
EXNESS_LOGIN=                      # Exness account login
EXNESS_PASSWORD=                   # Exness account password

# ── Payments ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # https://dashboard.stripe.com
STRIPE_WEBHOOK_SECRET=             # Stripe webhook signing secret
HYPERPAY_ACCESS_TOKEN=             # HyperPay (MENA payment gateway)

# ── Notifications ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                # BotFather → /newbot
DISCORD_WEBHOOK=                   # Discord server → Integrations → Webhooks
SENDGRID_API_KEY=                  # https://sendgrid.com
FCM_SERVER_KEY=                    # Firebase Cloud Messaging server key
TWILIO_SID=                        # Twilio Account SID (WhatsApp/SMS)
TWILIO_TOKEN=                      # Twilio auth token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox number (change in production)

# ── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development / staging / production

# ── Frontend (Next.js public URLs) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AUTH_URL=http://localhost:8001

# ── Internal Service URLs (Docker network) ─────────────────────────────────
NEWS_SVC_URL=http://news_ingestion_service:8007
ML_SVC_URL=http://ai_ml_service:8008
PATTERNS_SVC_URL=http://patterns_service:8009
PA_SVC_URL=http://price_action_service:8010
USER_SVC_URL=http://user_service:8011
WHALE_SVC_URL=http://whale_tracker_service:8012
RISK_SVC_URL=http://risk_manager_service:8013
NOTIF_SVC_URL=http://notification_service:8014
